 1 < json.length() && \n                        json.charAt(i+1) != '}' && json.charAt(i+1) != ']') {\n                        formatted.append(\"\\n\");\n                        for (int j = 0; j < depth; j++) formatted.append(indentation);\n                    }\n                } else if (c == '}' || c == ']') {\n                    while (formatted.length() > 0 && \n                           formatted.charAt(formatted.length()-1) == ' ') {\n                        formatted.deleteCharAt(formatted.length() - 1);\n                    }\n                    formatted.append(\"\\n\");\n                    depth--;\n                    for (int j = 0; j < depth; j++) formatted.append(indentation);\n                    formatted.append(c);\n                } else if (c == ',') {\n                    formatted.append(c).append(\"\\n\");\n                    for (int j = 0; j < depth; j++) formatted.append(indentation);\n                } else if (c == ':') {\n                    formatted.append(c).append(\" \");\n                } else if (c == ' ' || c == '\\n' || c == '\\r') {\n                    // Skip whitespace outside strings\n                } else {\n                    formatted.append(c);\n                }\n            } else {\n                formatted.append(c);\n            }\n            prevChar = c;\n        }\n        \n        return formatted.toString();\n    }\n\n    private Map<String, Object> error(Map<String, Object> result, String message) {\n        result.put(\"success\", false);\n        result.put(\"error\", message);\n        return result;\n    }\n}\n",
