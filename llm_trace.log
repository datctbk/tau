        "content": "package com.agent.service;\n\nimport org.springframework.beans.factory.annotation.Value;\nimport org.springframework.http.*;\nimport org.springframework.stereotype.Service;\nimport org.springframework.web.client.RestTemplate;\n\nimport java.util.*;\n\n/**\n * Client for Ollama LLM API.\n * Provides chat completion capabilities for reasoning and planning.\n */\n@Service\npublic class OllamaClient {\n\n    private static final String DEFAULT_MODEL = \"llama3:8b\";\n\n    @Value(\"${ollama.base.url:http://localhost:11434}\")\n    private String baseUrl;\n\n    @Value(\"${ollama.model:\" + DEFAULT_MODEL + \"}\")\n    private String model;\n\n    private final RestTemplate restTemplate = new RestTemplate();\n\n    /**\n     * Chat completion with a single message.\n     */\n    public String chat(String message) {\n        return chat(message, null);\n    }\n\n    /**\n     * Chat completion with optional system prompt.\n     */\n    public String chat(String message, String systemPrompt) {\n        List<Map<String, String>> messages = new ArrayList<>();\n\n        if (systemPrompt != null && !systemPrompt.isEmpty()) {\n            Map<String, String> systemMsg = new HashMap<>();\n            systemMsg.put(\"role\", \"system\");\n            systemMsg.put(\"content\", systemPrompt);\n            messages.add(systemMsg);\n        }\n\n        Map<String, String> userMsg = new HashMap<>();\n        userMsg.put(\"role\", \"user\");\n        userMsg.put(\"content\", message);\n        messages.add(userMsg);\n\n        return chat(messages);\n    }\n\n    /**\n     * Chat completion with message history.\n     */\n    public String chat(List<Map<String, String>> messages) {\n        Map<String, Object> requestBody = new HashMap<>();\n        requestBody.put(\"model\", model);\n        requestBody.put(\"messages\", messages);\n        requestBody.put(\"stream\", false);\n\n        String url = baseUrl + \"/api/chat\";\n\n        HttpEntity<Map<String, Object>> entity = new HttpEntity<>(requestBody);\n\n        try {\n            ResponseEntity<Map> response = restTemplate.postForEntity(url, entity, Map.class);\n\n            if (response.getStatusCode().is2xxSuccessful()) {\n                Map<String, Object> body = response.getBody();\n                if (body != null && body.containsKey(\"message\")) {\n                    Map<String, Object> message = (Map<String, Object>) body.get(\"message\");\n                    return (String) message.get(\"content\");\n                }\n            }\n\n            return \"Error: \" + response.getStatusCode();\n\n        } catch (Exception e) {\n            return \"Error: \" + e.getMessage();\n        }\n    }\n\n    /**\n     * Chat completion with streaming disabled (returns full response).\n     */\n    public String complete(String prompt) {\n        Map<String, Object> requestBody = new HashMap<>();\n        requestBody.put(\"model\", model);\n        requestBody.put(\"prompt\", prompt);\n        requestBody.put(\"stream\", false);\n\n        String url = baseUrl + \"/api/generate\";\n\n        HttpEntity<Map<String, Object>> entity = new HttpEntity<>(requestBody);\n\n        try {\n            ResponseEntity<Map> response = restTemplate.postForEntity(url, entity, Map.class);\n\n            if (response.getStatusCode().is2xxSuccessful()) {\n                Map<String, Object> body = response.getBody();\n                if (body != null && body.containsKey(\"response\")) {\n                    return (String) body.get(\"response\");\n                }\n            }\n\n            return \"Error: \" + response.getStatusCode();\n\n        } catch (Exception e) {\n            return \"Error: \" + e.getMessage();\n        }\n    }\n\n    /**\n     * Check if Ollama is available.\n     */\n    public boolean isAvailable() {\n        try {\n            ResponseEntity<String> response = restTemplate.getForEntity(baseUrl + \"/api/tags\", String.class);\n            return response.getStatusCode().is2xxSuccessful();\n        } catch (Exception e) {\n            return false;\n        }\n    }\n\n    /**\n     * Get available models.\n     */\n    public List<String> getModels() {\n        try {\n            ResponseEntity<Map> response = restTemplate.getForEntity(baseUrl + \"/api/tags\", Map.class);\n\n            if (response.getStatusCode().is2xxSuccessful()) {\n                Map<String, Object> body = response.getBody();\n                if (body != null && body.containsKey(\"models\")) {\n                    List<Map<String, Object>> models = (List<Map<String, Object>>) body.get(\"models\");\n                    List<String> modelNames = new ArrayList<>();\n                    for (Map<String, Object> m : models) {\n                        String name = (String) m.get(\"name\");\n                        if (name != null) {\n                            modelNames.add(name);\n                        }\n                    }\n                    return modelNames;\n                }\n            }\n        } catch (Exception e) {\n            // Ignore errors\n        }\n        return new ArrayList<>();\n    }\n\n    public String getModel() {\n        return model;\n    }\n\n    public void setModel(String model) {\n        this.model = model;\n    }\n}\n",
