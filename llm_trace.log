        "content": "package com.agent.service;\n\nimport com.agent.model.Step;\nimport com.agent.model.Task;\nimport com.agent.model.TaskResult;\nimport com.agent.tool.Tool;\nimport org.slf4j.Logger;\nimport org.slf4j.LoggerFactory;\nimport org.springframework.stereotype.Service;\n\nimport java.util.*;\nimport java.util.concurrent.ConcurrentHashMap;\nimport java.util.stream.Collectors;\n\n/**\n * Orchestrates step-by-step task execution.\n * Manages tool lookup, execution, and task state transitions.\n */\n@Service\npublic class TaskExecutor {\n\n    private static final Logger log = LoggerFactory.getLogger(TaskExecutor.class);\n\n    private final Map<String, Tool> tools;\n    private final Map<String, Task> pendingTasks = new ConcurrentHashMap<>();\n\n    public TaskExecutor(List<Tool> toolList) {\n        this.tools = new HashMap<>();\n        for (Tool tool : toolList) {\n            tools.put(tool.getName(), tool);\n            log.info(\"Registered tool: {}\", tool.getName());\n        }\n    }\n\n    /**\n     * Submit a task for execution.\n     */\n    public TaskResult submitTask(Task task) {\n        if (task.getId() == null || task.getId().isEmpty()) {\n            task.setId(\"task-\" + System.currentTimeMillis());\n        }\n\n        pendingTasks.put(task.getId(), task);\n        log.info(\"Task submitted: {} - {}\", task.getId(), task.getDescription());\n\n        return executeTask(task);\n    }\n\n    /**\n     * Execute a task step-by-step.\n     */\n    public TaskResult executeTask(Task task) {\n        TaskResult result = new TaskResult();\n        result.setTaskId(task.getId());\n\n        try {\n            task.setStatus(Task.TaskStatus.IN_PROGRESS);\n            log.info(\"Starting task execution: {}\", task.getId());\n\n            for (int i = 0; i < task.getSteps().size(); i++) {\n                Step step = task.getSteps().get(i);\n\n                // Update step status\n                step.setStatus(Step.StepStatus.EXECUTING);\n                log.debug(\"Executing step {}: {}\", i + 1, step.getToolName());\n\n                // Look up tool\n                Tool tool = tools.get(step.getToolName());\n                if (tool == null) {\n                    step.setStatus(Step.StepStatus.FAILED);\n                    step.setErrorMessage(\"Unknown tool: \" + step.getToolName());\n                    \n                    // Fail the entire task\n                    task.setStatus(Task.TaskStatus.FAILED);\n                    result.setSuccess(false);\n                    result.setError(\"Unknown tool: \" + step.getToolName());\n                    return result;\n                }\n\n                // Execute tool\n                try {\n                    Map<String, Object> output = tool.execute(step.getParameters());\n                    step.setOutput(convertToJsonString(output));\n                    \n                    if (Boolean.TRUE.equals(output.get(\"success\"))) {\n                        step.setStatus(Step.StepStatus.COMPLETED);\n                    } else {\n                        step.setStatus(Step.StepStatus.FAILED);\n                        String errorMsg = output.getOrDefault(\"error\", \"Unknown error\").toString();\n                        step.setErrorMessage(errorMsg);\n                        \n                        // Fail the entire task\n                        task.setStatus(Task.TaskStatus.FAILED);\n                        result.setSuccess(false);\n                        result.setError(\"Step failed: \" + errorMsg);\n                        return result;\n                    }\n\n                    log.debug(\"Step {} completed successfully\", i + 1);\n\n                } catch (Exception e) {\n                    step.setStatus(Step.StepStatus.FAILED);\n                    step.setErrorMessage(\"Execution error: \" + e.getMessage());\n                    \n                    task.setStatus(Task.TaskStatus.FAILED);\n                    result.setSuccess(false);\n                    result.setError(\"Step execution error: \" + e.getMessage());\n                    return result;\n                }\n            }\n\n            // All steps completed successfully\n            task.setStatus(Task.TaskStatus.COMPLETED);\n            result.setSuccess(true);\n            result.setMessage(\"Task completed successfully\");\n\n            log.info(\"Task completed: {}\", task.getId());\n\n        } catch (Exception e) {\n            task.setStatus(Task.TaskStatus.FAILED);\n            result.setSuccess(false);\n            result.setError(\"Task execution failed: \" + e.getMessage());\n            log.error(\"Task failed: {}\", task.getId(), e);\n        }\n\n        return result;\n    }\n\n    /**\n     * Get task status.\n     */\n    public Task getTask(String taskId) {\n        return pendingTasks.get(taskId);\n    }\n\n    /**\n     * Get all available tool names.\n     */\n    public List<String> getAvailableTools() {\n        return new ArrayList<>(tools.keySet());\n    }\n\n    /**\n     * Get tool description by name.\n     */\n    public String getToolDescription(String toolName) {\n        Tool tool = tools.get(toolName);\n        return tool != null ? tool.getDescription() : null;\n    }\n\n    /**\n     * Convert Map to JSON string (simple implementation).\n     */\n    private String convertToJsonString(Map<String, Object> map) {\n        StringBuilder sb = new StringBuilder(\"{\");\n        boolean first = true;\n        \n        for (Map.Entry<String, Object> entry : map.entrySet()) {\n            if (!first) sb.append(\", \");\n            first = false;\n            \n            sb.append(entry.getKey()).append(\": \");\n            sb.append(valueToString(entry.getValue()));\n        }\n        \n        sb.append(\"}\");\n        return sb.toString();\n    }\n\n    private String valueToString(Object value) {\n        if (value == null) {\n            return \"null\";\n        }\n        \n        if (value instanceof String) {\n            return \"\\\"\" + value.toString().replace(\"\\\\\", \"\\\\\\\\\")\n                                         .replace(\"\\\"\", \"\\\\\\\"\") + \"\\\"\";\n        }\n        \n        if (value instanceof Boolean || value instanceof Number) {\n            return value.toString();\n        }\n        \n        if (value instanceof Map) {\n            return convertToJsonString((Map<String, Object>) value);\n        }\n        \n        if (value instanceof List) {\n            StringBuilder sb = new StringBuilder(\"[\");\n            boolean first = true;\n            for (Object item : (List<?>) value) {\n                if (!first) sb.append(\", \");\n                first = false;\n                sb.append(valueToString(item));\n            }\n            sb.append(\"]\");\n            return sb.toString();\n        }\n        \n        return \"\\\"\" + value.toString() + \"\\\"\";\n    }\n}\n",
