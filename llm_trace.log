=========================\n        // Task B: Find minimum conversions\n        // =========================================\n\n        // Find all \"bridge\" water cells (adjacent to at least 2 different islands)\n        List<Cell> bridges = new ArrayList<>();\n        Set<String> bridgeSet = new HashSet<>();\n\n        for (int i = 0; i < n; i++) {\n            for (int j = 0; j < m; j++) {\n                if (grid[i][j] == '0') {\n                    int island1 = -1, island2 = -1;\n                    List<String> adjLand = new ArrayList<>();\n\n                    for (int k = 0; k < 4; k++) {\n                        int ni = i + DR[k];\n                        int nj = j + DC[k];\n                        if (ni >= 0 && ni < n && nj >= 0 && nj < m && grid[ni][nj] == '1') {\n                            adjLand.add(new String() { {\n                                // Find island ID\n                                for (int r = ni; r >= 0; r--) {\n                                    for (int c = nj; c >= 0; c--) {\n                                        // BFS backward to find island\n                                        if (visited[ni][nj]) {\n                                            // islandID stored in a way we can check\n                                            // For simplicity, we'll store coordinate hash\n                                        }\n                                    }\n                                }\n                            }});\n                            adjLand.add(ni + \",\" + nj);\n                        }\n                    }\n                    // Check if this water cell connects multiple islands\n                    // Use coordinate-based check\n                    if (adjLand.size() >= 2) {\n                        // Create a unique key for this water cell\n                        String key = i + \",\" + j + \",\" + adjLand.size();\n                        if (!bridgeSet.contains(key)) {\n             