        "content": "import java.io.*;\nimport java.nio.file.*;\nimport java.util.*;\nimport java.util.stream.*;\n\npublic class TaskManager {\n    private List<Task> tasks;\n    private String dataFile;\n    private int nextId;\n\n    public TaskManager(String dataFile) {\n        this.dataFile = dataFile;\n        this.tasks = new ArrayList<>();\n        loadTasks();\n    }\n\n    private void loadTasks() {\n        try {\n            if (new File(dataFile).exists()) {\n                String json = new String(Files.readAllBytes(Paths.get(dataFile)));\n                tasks = parseJson(json);\n                if (!tasks.isEmpty()) {\n                    nextId = tasks.stream().mapToInt(Task::getId).max().orElse(0) + 1;\n                } else {\n                    nextId = 1;\n                }\n            } else {\n                tasks = new ArrayList<>();\n                nextId = 1;\n            }\n        } catch (IOException e) {\n            System.err.println(\"Error loading tasks: \" + e.getMessage());\n            tasks = new ArrayList<>();\n            nextId = 1;\n        }\n    }\n\n    private List<Task> parseJson(String json) {\n        List<Task> taskList = new ArrayList<>();\n        // Simple JSON parser for our specific format\n        String content = json.trim();\n        if (content.equals(\"[]\")) return taskList;\n        \n        // Remove outer brackets\n        content = content.substring(1, content.length() - 1);\n        \n        // Split by \"},{\" to separate objects\n        String[] taskStrings = content.split(\"},\\{\\\");\n        \n        for (String taskStr : taskStrings) {\n            taskStr = taskStr.trim().replaceAll(\"^\\\\{|\\\\}$\", \"\");\n            \n            // Parse each field\n            int id = extractInt(taskStr, \"id\");\n            String desc = extractString(taskStr, \"description\");\n            String status = extractString(taskStr, \"status\");\n            String created = extractString(taskStr, \"created_at\");\n            \n            taskList.add(new Task(id, desc, status, created));\n        }\n        \n        return taskList;\n    }\n\n    private int extractInt(String json, String key) {\n        String pattern = \"\\\"\" + key + \"\\\":\\\\s*(\\\\d+)\";\n        java.util.regex.Matcher m = java.util.regex.Pattern.compile(pattern).matcher(json);\n        return m.find() ? Integer.parseInt(m.group(1)) : 0;\n    }\n\n    private String extractString(String json, String key) {\n        String pattern = \"\\\"\" + key + \"\\\":\\\\s*\\\"([^\\\"]*)\\\"\";\n        java.util.regex.Matcher m = java.util.regex.Pattern.compile(pattern).matcher(json);\n        return m.find() ? m.group(1) : \"\";\n    }\n\n    private void saveTasks() {\n        try {\n            StringBuilder json = new StringBuilder(\"[\");\n            for (int i = 0; i < tasks.size(); i++) {\n                if (i > 0) json.append(\",\");\n                Task t = tasks.get(i);\n                json.append(String.format(\"{\\\"id\\\":%d,\\\"description\\\":\\\"%s\\\",\\\"status\\\":\\\"%s\\\",\\\"created_at\\\":\\\"%s\\\"}\",\n                        t.getId(), t.getDescription(), t.getStatus(), t.getCreatedAt()));\n            }\n            json.append(\"]\");\n            \n            Files.write(Paths.get(dataFile), json.toString().getBytes());\n        } catch (IOException e) {\n            System.err.println(\"Error saving tasks: \" + e.getMessage());\n        }\n    }\n\n    public void addTask(String description) {\n        Task task = new Task(nextId++, description);\n        tasks.add(task);\n        saveTasks();\n        System.out.println(\"Task #\" + task.getId() + \" added\");\n    }\n\n    public void listTasks(String filterStatus) {\n        if (tasks.isEmpty()) {\n            System.out.println(\"No tasks found.\");\n            return;\n        }\n\n        // Print header\n        System.out.printf(\"%-4s | %-20s | %s%n\", \"ID\", \"Description\", \"Status\");\n        System.out.println(\"----|---------------------|-------\");\n\n        for (Task task : tasks) {\n            if (filterStatus == null || task.getStatus().equals(filterStatus)) {\n                String desc = task.getDescription().length() > 19 \n                        ? task.getDescription().substring(0, 16) + \"...\" \n                        : task.getDescription();\n                System.out.printf(\"%-4d | %-20s | %s%n\", task.getId(), desc, task.getStatus());\n            }\n        }\n    }\n\n    public void completeTask(int id) {\n        for (Task task : tasks) {\n            if (task.getId() == id) {\n                String oldStatus = task.getStatus();\n                if (oldStatus.equals(\"done\")) {\n                    System.out.println(\"Task #\" + id + \" is already complete.\");\n                } else {\n                    task.complete();\n                    saveTasks();\n                    System.out.println(\"Task #\" + id + \" marked as done\");\n                }\n                return;\n            }\n        }\n        System.out.println(\"Task #\" + id + \" not found.\");\n    }\n\n    public void deleteTask(int id) {\n        for (int i = 0; i < tasks.size(); i++) {\n            if (tasks.get(i).getId() == id) {\n                tasks.remove(i);\n                saveTasks();\n                System.out.println(\"Task #\" + id + \" deleted.\");\n                return;\n            }\n        }\n        System.out.println(\"Task #\" + id + \" not found.\");\n    }\n}\n"
      }
