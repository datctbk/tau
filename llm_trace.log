        "content": "package com.agent.tool;\n\nimport org.springframework.stereotype.Component;\n\nimport java.util.*;\n\n/**\n * Tool for pretty-printing JSON strings.\n */\n@Component\npublic class PrettyPrintJsonTool implements Tool {\n\n    @Override\n    public String getName() {\n        return \"pretty_print_json\";\n    }\n\n    @Override\n    public String getDescription() {\n        return \"Pretty-print a JSON string with configurable indentation.\";\n    }\n\n    @Override\n    public Map<String, Object> execute(Map<String, Object> params) {\n        Map<String, Object> result = new HashMap<>();\n        \n        try {\n            String jsonString = (String) params.get(\"json_string\");\n            int indent = (Integer) params.getOrDefault(\"indent\", 2);\n\n            if (jsonString == null || jsonString.isEmpty()) {\n                return error(result, \"Missing required parameter: json_string\");\n            }\n\n            // Simple JSON pretty-printing\n            String formatted = formatJson(jsonString.trim(), indent);\n\n            result.put(\"success\", true);\n            result.put(\"formatted_json\", formatted);\n\n        } catch (Exception e) {\n            return error(result, \"Invalid JSON: \" + e.getMessage());\n        }\n\n        return result;\n    }\n\n    private String formatJson(String json, int indent) {\n        StringBuilder formatted = new StringBuilder();\n        String indentation = \" \".repeat(indent);\n        boolean inString = false;\n        char prevChar = 0;\n        int depth = 0;\n        \n        for (int i = 0; i < json.length(); i++) {\n            char c = json.charAt(i);\n            \n            if (c == '\"' && (i == 0 || json.charAt(i-1) != '\\\\')) {\n                inString = !inString;\n            }\n            \n            if (!inString) {\n                if (c == '{' || c == '[') {\n                    formatted.append(c);\n                    depth++;\n                    if (i + 1 < json.length() && \n                        json.charAt(i+1) != '}' && json.charAt(i+1) != ']') {\n                        formatted.append(\"\\n\");\n                        for (int j = 0; j < depth; j++) formatted.append(indentation);\n                    }\n                } else if (c == '}' || c == ']') {\n                    while (formatted.length() > 0 && \n                           formatted.charAt(formatted.length()-1) == ' ') {\n                        formatted.deleteCharAt(formatted.length() - 1);\n                    }\n                    formatted.append(\"\\n\");\n                    depth--;\n                    for (int j = 0; j < depth; j++) formatted.append(indentation);\n                    formatted.append(c);\n                } else if (c == ',') {\n                    formatted.append(c).append(\"\\n\");\n                    for (int j = 0; j < depth; j++) formatted.append(indentation);\n                } else if (c == ':') {\n                    formatted.append(c).append(\" \");\n                } else if (c == ' ' || c == '\\n' || c == '\\r') {\n                    // Skip whitespace outside strings\n                } else {\n                    formatted.append(c);\n                }\n            } else {\n                formatted.append(c);\n            }\n            prevChar = c;\n        }\n        \n        return formatted.toString();\n    }\n\n    private Map<String, Object> error(Map<String, Object> result, String message) {\n        result.put(\"success\", false);\n        result.put(\"error\", message);\n        return result;\n    }\n}\n",
