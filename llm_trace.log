ach\n        \n        // Collect all water cells that can help connect\n        List<Cell> waterCells = new ArrayList<>();\n        int[][] adj = new int[n][m]; // adjacency: how many island cells are adjacent\n        \n        for (int i = 0; i < n; i++) {\n            for (int j = 0; j < m; j++) {\n                if (grid[i][j] == '0') {\n                    int adjacentLand = 0;\n                    for (int k = 0; k < 4; k++) {\n                        int ni = i + dr[k];\n                        int nj = j + dc[k];\n                        if (ni >= 0 && ni < n && nj >= 0 && nj < m) {\n                            if (grid[ni][nj] == '1') {\n                                adjacentLand++;\n                            }\n                        }\n                    }\n                    adj[i][j] = adjacentLand;\n                    waterCells.add(new Cell(i, j, 1));\n                }\n            }\n        }\n        \n        // If only 2 islands, connect them with min cost water cell\n        if (landIslands == 2) {\n            Collections.sort(waterCells, (a, b) -> {\n                return Integer.compare(a.adjacentLand, b.adjacentLand);\n            });\n            int minConversions = 1;\n            optimalCells.add(new int[]{waterCells.get(0).r, waterCells.get(0).c});\n            System.out.println(minConversions);\n            System.out.println(1);\n            return;\n        }\n        \n        // For multiple islands, we need to connect them optimally\n        // This is a Steiner Tree problem on grid\n        // Simplified: connect islands using minimum water cells\n        \n        // BFS from each island to find water cells\n        // Find minimum water cells needed\n        \n        // Simple approach: connect islands via water cells\n        // Use Prim's algorithm style\n        \n        PriorityQueue<Cell> pq = new PriorityQueue<>((a, b) -> {\n            // Sort by cost (adjacentLand), then lexicographically\n            if (a.adjacentLand != b.adjacentLand) {\n                return Integer.compare(a.adjacentLand, b.adjacentLand);\n            }\n            return compareCells(a, b);\n        });\n        \n        for (Cell cell : waterCells) {\n            cell.adjacentLand = adj[cell.r][cell.c];\n            pq.offer(cell);\n        }\n        \n        int totalConversions = 0;\n        while (!pq.isEmpty() && islandCount > 1) {\n            Cell cell = pq.poll();\n            \n            // Check if this cell can help connect\n            if (cell.adjacentLand > 0) {\n                // This cell is adjacent to land islands\n                // Connect it to the nearest land island\n                totalConversions++;\n                // Mark this cell as used conceptually\n                if (optimalCells.size() < 100) {\n                    optimalCells.add(new int[]{cell.r, cell.c});\n                }\n            }\n        }\n        \n        System.out.println(totalConversions);\n        System.out.println(1);\n    }\n    \n    static void floodFill(int r, int c) {\n        Queue<int[]> q = new LinkedList<>();\n        q.offer(new int[]{r, c});\n        visited[r][c] = islandCount;\n        \n        while (!q.isEmpty()) {\n            int[] cell = q.poll();\n            int cr = cell[0], cc = cell[1];\n            \n            for (int k = 0; k < 4; k++) {\n                int nr = cr + dr[k];\n                int nc = cc + dc[k];\n                \n                if (nr >= 0 && nr < n && nc >= 0 && nc < m &&\n                    grid[nr][nc] == '1' && visited[nr][nc] == 0) {\n                    visited[nr][nc] = islandCount;\n                    q.offer(new int[]{nr, nc});\n                }\n            }\n        }\n    }\n    \n    static int compareCells(Cell a, Cell b) {\n        if (a.r != b.r) return Integer.compare(a.r, b.r);\n        return Integer.compare(a.c, b.c);\n    }\n    \n    static class Cell {\n        int r, c, adjacentLand;\n        Cell(int r