        "content": "package com.agent.tool;\n\nimport com.fasterxml.jackson.databind.ObjectMapper;\nimport org.springframework.stereotype.Component;\n\nimport java.io.IOException;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.nio.file.Paths;\nimport java.util.HashMap;\nimport java.util.List;\nimport java.util.Map;\nimport java.util.stream.Collectors;\n\n/**\n * Tool for reading file contents.\n * Supports optional line range slicing (0-based, inclusive).\n */\n@Component\npublic class FileReadTool implements Tool {\n\n    private static final ObjectMapper mapper = new ObjectMapper();\n\n    @Override\n    public String getName() {\n        return \"read_file\";\n    }\n\n    @Override\n    public String getDescription() {\n        return \"Read the contents of a file. Optionally slice by line range (0-based). \" +\n               \"Returns lines prefixed with line numbers.\";\n    }\n\n    @Override\n    public Map<String, Object> execute(Map<String, Object> params) {\n        Map<String, Object> result = new HashMap<>();\n        \n        try {\n            String path = (String) params.get(\"path\");\n            if (path == null || path.isEmpty()) {\n                return error(result, \"Missing required parameter: path\");\n            }\n\n            Path filePath = Paths.get(path);\n            if (!Files.exists(filePath)) {\n                // Try relative to current working directory\n                Path absolutePath = Paths.get(System.getProperty(\"user.dir\"), path);\n                if (Files.exists(absolutePath)) {\n                    filePath = absolutePath;\n                } else {\n                    return error(result, \"File not found: \" + path);\n                }\n            }\n\n            if (Files.isDirectory(filePath)) {\n                return error(result, \"Path is a directory, not a file: \" + path);\n            }\n\n            List<String> lines = Files.readAllLines(filePath);\n            \n            // Apply optional line range slicing\n            Integer startLine = params.containsKey(\"start_line\") ? \n                (Integer) params.get(\"start_line\") : 0;\n            Integer endLine = params.containsKey(\"end_line\") ? \n                (Integer) params.get(\"end_line\") : lines.size() - 1;\n\n            if (endLine == -1) {\n                endLine = lines.size() - 1;\n            }\n\n            if (startLine > endLine) {\n                return error(result, \"start_line cannot be greater than end_line\");\n            }\n\n            List<String> slicedLines = lines.subList(\n                Math.max(0, startLine), \n                Math.min(endLine + 1, lines.size())\n            );\n\n            // Format with line numbers (using original line numbers)\n            String formatted = slicedLines.stream()\n                .map((line, idx) -> String.format(\"%d|%s\", startLine + idx, line))\n                .collect(Collectors.joining(\"\\n\"));\n\n            result.put(\"success\", true);\n            result.put(\"content\", formatted);\n            result.put(\"total_lines\", lines.size());\n            result.put(\"lines_read\", slicedLines.size());\n\n        } catch (IOException e) {\n            return error(result, \"IO error: \" + e.getMessage());\n        } catch (Exception e) {\n            return error(result, \"Error: \" + e.getMessage());\n        }\n\n        return result;\n    }\n\n    private Map<String, Object> error(Map<String, Object> result, String message) {\n        result.put(\"success\", false);\n        result.put(\"error\", message);\n        return result;\n    }\n\n    @FunctionalInterface\n    interface BiFunction<T, U, R> {\n        R apply(T t, U u);\n    }\n}\n",
