onse = self._process_request(message)\n        \n        # Add response to history\n        self.conversation_history.append({\"role\": \"assistant\", \"content\": response})\n        \n        return response\n    \n    def _process_request(self, message: str) -> str:\n        \"\"\"Route request to appropriate tool.\"\"\"\n        # Simple keyword-based routing (real agents use LLM for this)\n        if \"read\" in message.lower() and \"file\" in message.lower():\n            # Extract filename (simplified)\n            parts = message.split()\n            filepath = parts[-1] if parts else \"unknown\"\n            result = self.tools[\"read_file\"].execute(path=filepath)\n            return f\"File read: {result.output}\"\n        \n        elif \"run\" in message.lower() or \"exec\" in message.lower():\n            result = self.tools[\"run_shell\"].execute(command=\"echo hello\")\n            return f\"Shell output: {result.output}\"\n        \n        else:\n            return f\"I'm a simple agent. Try 'read file path' or 'run command'\"\n    \n    def get_context(self) -> Dict:\n        \"\"\"Return agent's current state for inspection.\"\"\"\n        return {\n            \"name\": self.name,\n            \"tools_available\": list(self.tools.keys()),\n            \"conversation_length\": len(self.conversation_history)\n        }\n\n\ndef main():\n    # Create agent with tools\n    tools = [\n        FileReadTool(),\n        ShellTool()\n    ]\n    \n    agent = Agent(name=\"tau\", tools=tools)\n    \n    print(f\"Agent {agent.name} initialized with {len(tools)} tools\")\n    print(json.dumps(agent.get_context(), indent=2))\n    \n    # Example interaction\n    print(\"\\n--- Example Interaction ---\")\n    response = agent.communicate(\"read file README.md\")\n    print(f\"Agent: {response}\")\n\n\nif __name__ == \"__main__\":\n    main()\n"
