        "content": "package com.agent.tool;\n\nimport org.springframework.stereotype.Component;\n\nimport java.util.*;\n\n/**\n * Tool for counting words, lines, and characters in text.\n */\n@Component\npublic class WordCountTool implements Tool {\n\n    @Override\n    public String getName() {\n        return \"word_count\";\n    }\n\n    @Override\n    public String getDescription() {\n        return \"Count the number of words, lines, and characters in a text string.\";\n    }\n\n    @Override\n    public Map<String, Object> execute(Map<String, Object> params) {\n        Map<String, Object> result = new HashMap<>();\n        \n        try {\n            String text = (String) params.get(\"text\");\n\n            if (text == null) {\n                return error(result, \"Missing required parameter: text\");\n            }\n\n            int charCount = text.length();\n            int lineCount = text.isEmpty() ? 0 : text.split(\"\\\\n\").length;\n            \n            // Word count: split by whitespace, filter empty strings\n            String[] words = text.trim().split(\"\\\\s+\");\n            int wordCount = text.trim().isEmpty() ? 0 : words.length;\n\n            result.put(\"success\", true);\n            result.put(\"words\", wordCount);\n            result.put(\"lines\", lineCount);\n            result.put(\"characters\", charCount);\n\n        } catch (Exception e) {\n            return error(result, \"Error: \" + e.getMessage());\n        }\n\n        return result;\n    }\n\n    private Map<String, Object> error(Map<String, Object> result, String message) {\n        result.put(\"success\", false);\n        result.put(\"error\", message);\n        return result;\n    }\n}\n",
