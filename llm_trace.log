        "content": "package com.agent.tool;\n\nimport org.springframework.stereotype.Component;\n\nimport java.io.IOException;\nimport java.nio.file.Files;\nimport java.nio.file.Path;\nimport java.nio.file.Paths;\nimport java.util.HashMap;\nimport java.util.List;\nimport java.util.Map;\n\n/**\n * Tool for replacing exact strings in files.\n */\n@Component\npublic class FileEditTool implements Tool {\n\n    @Override\n    public String getName() {\n        return \"edit_file\";\n    }\n\n    @Override\n    public String getDescription() {\n        return \"Replace an exact string in a file with a new string. \" +\n               \"old_str must appear exactly once in the file.\";\n    }\n\n    @Override\n    public Map<String, Object> execute(Map<String, Object> params) {\n        Map<String, Object> result = new HashMap<>();\n        \n        try {\n            String path = (String) params.get(\"path\");\n            String oldStr = (String) params.get(\"old_str\");\n            String newStr = (String) params.get(\"new_str\");\n\n            if (path == null || path.isEmpty()) {\n                return error(result, \"Missing required parameter: path\");\n            }\n\n            if (oldStr == null || oldStr.isEmpty()) {\n                return error(result, \"Missing required parameter: old_str\");\n            }\n\n            if (newStr == null) {\n                return error(result, \"Missing required parameter: new_str\");\n            }\n\n            Path filePath = Paths.get(path);\n            \n            if (!Files.exists(filePath)) {\n                return error(result, \"File not found: \" + path);\n            }\n\n            // Read file content\n            String content = new String(Files.readAllBytes(filePath));\n            \n            // Count occurrences\n            int count = countOccurrences(content, oldStr);\n            if (count == 0) {\n                return error(result, \"old_str not found in file\");\n            } else if (count > 1) {\n                return error(result, \"old_str appears \" + count + \" times, expected exactly once\");\n            }\n\n            // Replace\n            String newContent = content.replaceFirst(\n                oldStr.replace(\"(\", \"\\\\(\").replace(\")\", \"\\\\)\")\n                       .replace(\"[\", \"\\\\[\").replace(\"]\", \"\\\\]\")\n                       .replace(\"{\", \"\\\\{\").replace(\"}\", \"\\\\}\")\n                       .replace(\"*\", \"\\\\*\").replace(\"?\", \"\\\\?\")\n                       .replace(\".\", \"\\\\.\"),\n                newStr\n            );\n            \n            // Simple exact replacement\n            int index = content.indexOf(oldStr);\n            if (index == -1) {\n                return error(result, \"old_str not found in file\");\n            }\n            newContent = content.substring(0, index) + newStr + \n                        content.substring(index + oldStr.length());\n\n            Files.write(filePath, newContent.getBytes());\n\n            result.put(\"success\", true);\n            result.put(\"message\", \"File updated successfully\");\n            result.put(\"bytes_written\", newContent.length());\n\n        } catch (IOException e) {\n            return error(result, \"IO error: \" + e.getMessage());\n        } catch (Exception e) {\n            return error(result, \"Error: \" + e.getMessage());\n        }\n\n        return result;\n    }\n\n    private int countOccurrences(String text, String pattern) {\n        int count = 0;\n        int index = 0;\n        while ((index = text.indexOf(pattern, index)) != -1) {\n            count++;\n            index += pattern.length();\n        }\n        return count;\n    }\n\n    private Map<String, Object> error(Map<String, Object> result, String message) {\n        result.put(\"success\", false);\n        result.put(\"error\", message);\n        return result;\n    }\n}\n"
