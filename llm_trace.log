        "content": "package com.agent.tool;\n\nimport org.springframework.stereotype.Component;\n\nimport java.io.*;\nimport java.util.*;\n\n/**\n * Tool for running bash commands and returning output.\n */\n@Component\npublic class BashTool implements Tool {\n\n    @Override\n    public String getName() {\n        return \"run_bash\";\n    }\n\n    @Override\n    public String getDescription() {\n        return \"Run a shell (bash) command and return stdout, stderr, and exit code. \" +\n               \"Use for running tests, installing packages, compiling, etc.\";\n    }\n\n    @Override\n    public Map<String, Object> execute(Map<String, Object> params) {\n        Map<String, Object> result = new HashMap<>();\n        \n        try {\n            String command = (String) params.get(\"command\");\n            String workDir = (String) params.getOrDefault(\"workdir\", \".\");\n\n            if (command == null || command.isEmpty()) {\n                return error(result, \"Missing required parameter: command\");\n            }\n\n            // Build process\n            List<String> cmdList = new ArrayList<>();\n            cmdList.add(\"/bin/bash\");\n            cmdList.add(\"-c\");\n            cmdList.add(command);\n\n            ProcessBuilder pb = new ProcessBuilder(cmdList);\n            pb.directory(new java.io.File(workDir));\n\n            Process process = pb.start();\n            \n            // Capture stdout and stderr\n            try (BufferedReader stdoutReader = new BufferedReader(\n                         new InputStreamReader(process.getInputStream()));\n                 BufferedReader stderrReader = new BufferedReader(\n                         new InputStreamReader(process.getErrorStream()))) {\n\n                StringBuilder stdout = new StringBuilder();\n                StringBuilder stderr = new StringBuilder();\n                String line;\n\n                // Read stdout\n                while ((line = stdoutReader.readLine()) != null) {\n                    stdout.append(line).append(\"\\n\");\n                }\n\n                // Read stderr\n                while ((line = stderrReader.readLine()) != null) {\n                    stderr.append(line).append(\"\\n\");\n                }\n\n                int exitCode = process.waitFor();\n\n                result.put(\"success\", exitCode == 0);\n                result.put(\"exit_code\", exitCode);\n                result.put(\"stdout\", stdout.toString().trim());\n                result.put(\"stderr\", stderr.toString().trim());\n\n            } finally {\n                process.destroy();\n            }\n\n        } catch (Exception e) {\n            return error(result, \"Error: \" + e.getMessage());\n        }\n\n        return result;\n    }\n\n    private Map<String, Object> error(Map<String, Object> result, String message) {\n        result.put(\"success\", false);\n        result.put(\"error\", message);\n        return result;\n    }\n}\n",
